{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/pokelytro/browser"
      }
    }
  ],
  "routes": [
    {
      "src": "^/(.*\\.(js|css|svg|ico|png|jpg|jpeg|etc)?)$",
      "dest": "/$1"
    },
    {
      "src": "^/api/(.*)",
      "dest": "https://pokelytro-backend.vercel.app/api/$1"
    },
    {
      "src": ".*",
      "dest": "/index.html"
    }
  ]
}
