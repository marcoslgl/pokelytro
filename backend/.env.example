# Example environment variables for the backend
# Copy this file to `.env` and fill values before running the server.

# MongoDB connection string (do NOT commit secrets to git).
# Example using Atlas:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/mydatabase?retryWrites=true&w=majority
# Example local Mongo:
# MONGODB_URI=mongodb://127.0.0.1:27017/pokelytro
MONGODB_URI=

# Server port (optional, defaults to 3000)
PORT=

